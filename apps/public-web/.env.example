# XCripto public site (apps/public-web) — environment variables.
# Copy to .env.local for local dev. Never commit real values.

# Backend XMIP public API base URL (server-side SSR fetches). No trailing slash.
# Local dev against the api container / uvicorn: http://localhost:8000
XCRIPTO_API_URL=http://localhost:8000

# Public site base URL (used for metadataBase, sitemap link, RSS discovery).
# The backend also returns canonical/OG URLs; keep these consistent in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site display name / brand.
NEXT_PUBLIC_SITE_NAME=XCripto
