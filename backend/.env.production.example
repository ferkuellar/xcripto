# XMIP Backend — production environment template.
#
# Copy this file to your production secret store / deployment environment.
# Do not commit real secrets.

APP_NAME=XMIP Backend
ENVIRONMENT=production
DEBUG=false

# Production database contract.
DATABASE_URL=postgresql+asyncpg://xmip:<password>@<host>:5432/xmip
AUTO_CREATE_TABLES=false

# Public web and API origins.
PUBLIC_WEB_BASE_URL=https://xcripto.com.mx
CORS_ALLOWED_ORIGINS=https://xcripto.com.mx,https://www.xcripto.com.mx,https://admin.xcripto.com.mx
CORS_ALLOW_CREDENTIALS=true

# Required for deployed environments.
AUTH_ENABLED=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_NAME=xmip_session
SESSION_TTL_SECONDS=43200

# Legacy API key auth remains available only for local/dev compatibility.
API_KEY=
API_KEY_HEADER_NAME=X-API-Key

REQUEST_LOGGING_ENABLED=true
REQUEST_BODY_LOGGING_ENABLED=false
RESPONSE_BODY_LOGGING_ENABLED=false
REQUEST_TIMEOUT_SECONDS=30
OPERATIONAL_AUDIT_ENABLED=true
DB_HEALTHCHECK_ENABLED=true
LOG_LEVEL=INFO

# Optional / deferred integrations. Keep empty unless intentionally enabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
BINANCE_SQUARE_OPENAPI_KEY=

# Real connectors remain disabled until explicitly enabled.
CONNECTORS_ENABLED=false
RSS_CONNECTOR_ENABLED=false
CONNECTOR_RUN_MODE=manual
CONNECTOR_AUDIT_ENABLED=true
CONNECTOR_REQUIRE_SOURCE_REFERENCE=true
CONNECTOR_AUTO_PROMOTE=false
