# XMIP Backend — configuración local PRODUCTION-LIKE.
# Copiar a .env para correr el backend local con mentalidad de producción.
#
# ⚠️ "dev-secret" es un valor SOLO para pruebas locales. Nunca usar en un
# despliegue real ni commitear un secreto verdadero en ningún .env.

APP_NAME=XMIP Backend
ENVIRONMENT=production
DEBUG=false

# Auth por API key activada (production-like). El frontend/scripts locales
# deben enviar X-API-Key: dev-secret.
AUTH_ENABLED=true
API_KEY=dev-secret
API_KEY_HEADER_NAME=X-API-Key

# En production-like las tablas se crean SOLO vía Alembic:
#   alembic upgrade head
AUTO_CREATE_TABLES=false

# Base local. SQLite para pruebas rápidas; PostgreSQL vía docker compose:
# DATABASE_URL=postgresql+asyncpg://xmip:xmip@localhost:5432/xmip
DATABASE_URL=sqlite+aiosqlite:///./xmip_local_prod.db

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

REQUEST_LOGGING_ENABLED=true
REQUEST_BODY_LOGGING_ENABLED=false
RESPONSE_BODY_LOGGING_ENABLED=false
OPERATIONAL_AUDIT_ENABLED=true
DB_HEALTHCHECK_ENABLED=true
LOG_LEVEL=INFO

# Real connectors (P9) — OFF by default; enable only for a controlled staging run.
CONNECTORS_ENABLED=false
RSS_CONNECTOR_ENABLED=false
RSS_CONNECTOR_ALLOWED_DOMAINS=coindesk.com,cointelegraph.com,decrypt.co,theblock.co
CONNECTOR_AUTO_PROMOTE=false
