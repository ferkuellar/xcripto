# XMIP Backend environment variables. Copy to .env and adjust.

# local | dev | staging | prod | test
ENVIRONMENT=local

# Local default uses SQLite (no server required). For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://xmip:xmip@localhost:5432/xmip
DATABASE_URL=sqlite+aiosqlite:///./xmip.db

# Create tables automatically at startup (disable once Alembic migrations exist).
AUTO_CREATE_TABLES=true

CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
