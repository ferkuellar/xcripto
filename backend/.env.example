# XMIP Backend environment variables. Copy to .env and adjust.

# Application metadata
APP_NAME=XMIP Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Database
# Local default uses SQLite. Use PostgreSQL for staging/production.
DATABASE_URL=sqlite+aiosqlite:///./xmip.db
AUTO_CREATE_TABLES=false
DB_HEALTHCHECK_ENABLED=true

# CORS
# Use explicit frontend/admin origins. Do not use "*" in production with auth enabled.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key,X-Correlation-ID,X-Actor-Id,X-Actor-Role,X-Actor-Display

# Minimal API key auth for write endpoints.
AUTH_ENABLED=false
API_KEY=
API_KEY_HEADER_NAME=X-API-Key

# Logging and audit behavior
REQUEST_LOGGING_ENABLED=true
REQUEST_BODY_LOGGING_ENABLED=false
RESPONSE_BODY_LOGGING_ENABLED=false
OPERATIONAL_AUDIT_ENABLED=true

# Docker Compose PostgreSQL defaults. Override in real environments.
POSTGRES_USER=xmip
POSTGRES_PASSWORD=xmip
POSTGRES_DB=xmip
