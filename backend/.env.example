# XMIP Backend environment variables. Copy to .env and adjust.

# local | dev | staging | prod | test
ENVIRONMENT=local

# Local default uses SQLite (no server required).
# For PostgreSQL / Docker:
# DATABASE_URL=postgresql+asyncpg://xmip:xmip@localhost:5432/xmip
DATABASE_URL=sqlite+aiosqlite:///./xmip.db

# Local/dev convenience only. Use Alembic migrations with false in staging/prod.
AUTO_CREATE_TABLES=true

CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO

# Minimal API key auth for write endpoints. Keep false for local/test by default.
AUTH_ENABLED=false
API_KEY=
API_KEY_HEADER_NAME=X-API-Key
