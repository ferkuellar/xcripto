# XMIP Backend environment variables. Copy to .env and adjust.

# Application metadata
APP_NAME=XMIP Backend
APP_VERSION=0.1.0
# ENVIRONMENT is the canonical name; APP_ENV is accepted as a deploy-provider alias.
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Database
# Local default uses SQLite. Use PostgreSQL for staging/production.
DATABASE_URL=sqlite+aiosqlite:///./xmip.db
AUTO_CREATE_TABLES=false
DB_HEALTHCHECK_ENABLED=true

# CORS
# Use explicit frontend/admin origins. Do not use "*" in production with auth enabled.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key,X-Correlation-ID,X-Actor-Id,X-Actor-Role,X-Actor-Display

# Public website base URL used to build published article links.
# PUBLIC_SITE_URL and APP_DOMAIN remain accepted aliases for backward compatibility.
PUBLIC_WEB_BASE_URL=http://localhost:3000

# Minimal API key auth for write endpoints.
AUTH_ENABLED=false
API_KEY=
API_KEY_HEADER_NAME=X-API-Key
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
BINANCE_SQUARE_OPENAPI_KEY=

# Logging and audit behavior
REQUEST_LOGGING_ENABLED=true
REQUEST_BODY_LOGGING_ENABLED=false
RESPONSE_BODY_LOGGING_ENABLED=false
REQUEST_TIMEOUT_SECONDS=30
OPERATIONAL_AUDIT_ENABLED=true

# Docker Compose PostgreSQL defaults. Override in real environments.
POSTGRES_USER=xmip
POSTGRES_PASSWORD=xmip
POSTGRES_DB=xmip

# Real connectors (P9). Disabled by default; kill switches. Ingest creates IntakeSignals
# (never publishes). CONNECTOR_AUTO_PROMOTE must stay false.
CONNECTORS_ENABLED=false
RSS_CONNECTOR_ENABLED=false
RSS_CONNECTOR_MAX_ITEMS=20
RSS_CONNECTOR_TIMEOUT_SECONDS=10
RSS_CONNECTOR_USER_AGENT=XMIP-StagingBot/0.1
RSS_CONNECTOR_ALLOWED_DOMAINS=coindesk.com,cointelegraph.com,decrypt.co,theblock.co
CONNECTOR_RUN_MODE=manual
CONNECTOR_AUDIT_ENABLED=true
CONNECTOR_REQUIRE_SOURCE_REFERENCE=true
CONNECTOR_AUTO_PROMOTE=false
