# XMIP Frontend — variables de entorno. Copiar a .env.local y ajustar.

# Base URL del backend XMIP (FastAPI). Sin slash final.
# Stack VPS-like directo: http://127.0.0.1:8000 · vía Caddy: https://127.0.0.1
VITE_API_BASE_URL=http://127.0.0.1:8000

# Valor browser-exposed. Solo para desarrollo interno o consola admin controlada.
# Nunca usar un secreto real de producción en ningún valor VITE_*.
VITE_API_KEY=

# Contexto RBAC. Se envía como X-Actor-Role / X-Actor-Id en escrituras y en el
# cliente admin. El backend lo exige para operaciones permisionadas:
#   intake.promote, readiness.calculate, operational_audit.read, admin/*
# 'admin' cubre los read models; para Operational Audit usar un rol con permiso
# operational_audit.read (p. ej. 'system'). No es autenticación pública de prod.
VITE_ACTOR_ROLE=admin
VITE_ACTOR_ID=local-admin
