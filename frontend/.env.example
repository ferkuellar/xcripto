# XMIP Frontend — variables de entorno. Copiar a .env.local y ajustar.

# Base URL del backend XMIP (FastAPI). Sin slash final.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Solo si el backend corre con AUTH_ENABLED=true (endpoints de escritura).
# Nunca commitear el valor real.
VITE_API_KEY=

# Contexto RBAC para el admin interno local.
# No usar estos valores como autenticación pública de producción.
VITE_ACTOR_ROLE=admin
VITE_ACTOR_ID=local-admin
