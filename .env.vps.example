# XMIP VPS deployment — copy to `.env.vps` and fill real values. NEVER commit .env.vps.
# DNS: point A records for APP_DOMAIN and API_DOMAIN to the VPS IP BEFORE first start
# (Caddy needs them resolvable to issue TLS certificates).

# Domains
APP_DOMAIN=xmip.example.com
API_DOMAIN=api.xmip.example.com
ACME_EMAIL=you@example.com

# PostgreSQL (runs on the VPS; not exposed publicly)
POSTGRES_USER=xmip
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=xmip

# Backend API key (staging secret — NOT a real production key)
API_KEY=change-me-staging-api-key

# Frontend build key: embedded and PUBLIC in the SPA bundle. Use the SAME value as
# API_KEY. Acceptable only for internal staging behind restricted access; P10 replaces
# this with real auth.
VITE_API_KEY=change-me-staging-api-key
